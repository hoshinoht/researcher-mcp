# Anti-blocking defaults
SCHOLAR_MIN_DELAY=3
SCHOLAR_MAX_DELAY=8
SCHOLAR_MAX_RETRIES=5
SCHOLAR_BACKOFF_FACTOR=2.0
SCHOLAR_ROTATE_USER_AGENTS=true
SCHOLAR_USER_AGENTS=
SCHOLAR_PROXY_LIST=
SCHOLAR_TIMEOUT_SECONDS=25

# Provider API keys (optional)
# Add keys/tokens below if you need higher usage limits or better throughput.
# You can obtain them from each provider's developer portal.
OPENALEX_API_KEY=
CROSSREF_API_KEY=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
